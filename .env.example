# Copy to `.env.local` and fill in values. Do not commit `.env.local`.

# Chat (required for /api/chat)
ANTHROPIC_API_KEY=

# Optional: LangSmith tracing (EU example)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=TennisCoach

# Legacy names (SDK also reads these)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=

# RAG / PDF ingest (optional for local dev)
CHROMADB_API_KEY=
CHROMADB_TENANT=
CHROMADB_DATABASE=
CHROMADB_CLOUD=

OPENROUTER_API_KEY=

PDF_CHUNK_SIZE=2500
PDF_CHUNK_OVERLAP=250
